{
  "name": "@akit/contracts",
  "version": "1.1.0",
  "description": "Shared TypeScript interfaces and contracts between Frontend and Backend",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json",
    "dev": "tsc -p tsconfig.esm.json --watch",
    "export:json": "tsx src/export-json-schemas.ts",
    "generate:android": "pnpm run export:json && tsx src/generate-android-models.ts"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.13",
    "quicktype-core": "^23.2.6",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0",
    "vitest": "^4.1.6",
    "zod-to-json-schema": "^3.24.6"
  }
}
