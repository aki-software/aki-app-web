{
  "info": {
    "_postman_id": "8f4f8e2e-bb7a-4d4d-9e4a-akit-backend-testing",
    "name": "Akit Backend Testing",
    "description": "Coleccion para validar autenticacion, test individual y test con voucher/codigo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "adminEmail", "value": "admin@akit.app" },
    { "key": "adminPassword", "value": "admin123" },
    { "key": "accessToken", "value": "" },
    { "key": "patientUserId", "value": "" },
    { "key": "individualSessionId", "value": "" },
    { "key": "therapistUserId", "value": "" },
    { "key": "voucherPatientUserId", "value": "" },
    { "key": "voucherSessionId", "value": "" },
    { "key": "voucherCode", "value": "THERA001" }
  ],
  "item": [
    {
      "name": "01 Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status ok', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json?.tokens?.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.tokens.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Obtiene el JWT del admin y lo guarda en accessToken."
          }
        }
      ]
    },
