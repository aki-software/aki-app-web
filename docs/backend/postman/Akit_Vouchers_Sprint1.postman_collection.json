              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/vouchers/{{voucherId}}/send-email",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vouchers",
                "{{voucherId}}",
                "send-email"
              ]
            }
          }
        }
      ]
    }
  ],
