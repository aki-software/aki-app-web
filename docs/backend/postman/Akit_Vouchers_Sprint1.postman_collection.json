{
  "info": {
    "name": "Akit API - Vouchers Sprint 1",
    "_postman_id": "0bdb5cc9-6ec4-4a7f-9aa3-6b35f0ca31aa",
    "description": "Coleccion para validar el contrato de vouchers del Sprint 1.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200/201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json && json.tokens && json.tokens.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.tokens.accessToken);",
                  "}",
                  "pm.test('Se guardo accessToken', function () {",
                  "  pm.expect(pm.collectionVariables.get('accessToken')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Vouchers - Redeem",
      "item": [
        {
          "name": "Redeem Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{voucherCode}}\",\n  \"sessionId\": \"{{sessionIdA}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/vouchers/redeem",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vouchers",
                "redeem"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Respuesta de canje valida', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(['REDEEMED', 'ALREADY_REDEEMED_BY_THIS_SESSION']).to.include(json.status);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Redeem Idempotent Same Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{voucherCode}}\",\n  \"sessionId\": \"{{sessionIdA}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/vouchers/redeem",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vouchers",
                "redeem"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Idempotencia por sesion', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.status).to.eql('ALREADY_REDEEMED_BY_THIS_SESSION');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Redeem Invalid Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"ZZ99YY88\",\n  \"sessionId\": \"{{sessionIdA}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/vouchers/redeem",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vouchers",
                "redeem"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "const json = pm.response.json();",
                  "const message = Array.isArray(json.message) ? json.message.join(' ') : String(json.message || '');",
                  "pm.test('Mensaje INVALID_CODE', function () {",
                  "  pm.expect(message).to.include('INVALID_CODE');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Redeem Already Used (Other Session)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{usedVoucherCode}}\",\n  \"sessionId\": \"{{sessionIdB}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/vouchers/redeem",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vouchers",
                "redeem"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 409', function () {",
                  "  pm.response.to.have.status(409);",
                  "});",
                  "const json = pm.response.json();",
                  "const message = Array.isArray(json.message) ? json.message.join(' ') : String(json.message || '');",
                  "pm.test('Mensaje ALREADY_USED', function () {",
                  "  pm.expect(message).to.include('ALREADY_USED');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Redeem Validation Error (Bad Code Length)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"ABC123\",\n  \"sessionId\": \"{{sessionIdA}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/vouchers/redeem",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vouchers",
                "redeem"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
