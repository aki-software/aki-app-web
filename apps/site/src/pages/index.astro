---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Radar from '../components/Radar.astro';
import Institutions from '../components/Institutions.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
import { translations } from '../i18n/translations';

const locale = 'es';
const t = translations[locale];
---

<BaseLayout locale={locale} t={t} title="ORIENT A.KI — Descubrí tu vocación en 10 minutos">
  <main id="main">
    <Navbar locale={locale} t={t} />
    <Hero locale={locale} t={t} />
    <HowItWorks locale={locale} t={t} />
    <Radar locale={locale} t={t} />
    <Institutions locale={locale} t={t} />
    <Pricing locale={locale} t={t} />
    <FAQ locale={locale} t={t} />
    <FinalCta locale={locale} t={t} />
    <Footer locale={locale} t={t} />
  </main>
</BaseLayout>
