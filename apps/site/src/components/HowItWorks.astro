---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { t } = Astro.props;
---

<section class="py-20 md:py-24 bg-bg" id="como-funciona">
  <div class="container">
    <div class="text-center mb-14">
      <h2 class="font-display font-extrabold text-3xl sm:text-4xl text-text mb-4">
        {t.howItWorks.title}
      </h2>
      <p class="text-lg text-text-muted">
        {t.howItWorks.subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-14">
      {t.howItWorks.steps.map((step, index) => {
        const icons = ['🃏', '📊', '📄'];
        return (
          <div class="flex flex-col items-center text-center gap-5">
            <div class="w-14 h-14 rounded-full bg-primary flex items-center justify-center">
              <span class="text-2xl font-extrabold text-surface">{index + 1}</span>
            </div>
            <div class="w-48 h-48 rounded-3xl bg-primary-light flex items-center justify-center">
              <span class="text-6xl">{icons[index]}</span>
            </div>
            <h3 class="font-display font-bold text-xl text-text">{step.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed max-w-xs">{step.desc}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
