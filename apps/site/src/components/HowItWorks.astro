---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { locale, t } = Astro.props;

const studentIcons = [
  // Icono 1: Swipe (Tinder-style swipe)
  `<svg class="w-6 h-6 text-primary-light" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
  </svg>`,
  // Icono 2: Perfil (AI Profile analysis)
  `<svg aria-hidden="true" class="w-6 h-6 text-confirm" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
  </svg>`,
  // Icono 3: Reporte PDF
  `<svg aria-hidden="true" class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
  </svg>`
];

const institutionIcons = [
  // Icono 1: Acceso (Dashboard Request)
  `<svg aria-hidden="true" class="w-6 h-6 text-primary-light" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
  </svg>`,
  // Icono 2: Vouchers (Ticket coupon)
  `<svg aria-hidden="true" class="w-6 h-6 text-confirm" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
  </svg>`,
  // Icono 3: Analytics (Dashboard interactivo)
  `<svg aria-hidden="true" class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4M8 21h8a2 2 0 002-2v-9a2 2 0 00-2-2H8a2 2 0 00-2 2v9a2 2 0 002 2z"/>
  </svg>`
];
---

<section class="py-24 md:py-32 relative bg-[#F5EFE7] overflow-hidden" id="como-funciona">
  <div class="container relative z-10">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-[#8E5A12]/20 mb-6 reveal shadow-sm">
        <p class="text-[11px] font-medium text-[#8E5A12] tracking-widest uppercase">
          EL PROCESO
        </p>
      </div>
      <h2 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl text-[#1F2523] mb-6 reveal reveal-delay-1 tracking-tight">
        {t.howItWorks.title}
      </h2>
      <p class="text-lg text-[#44403C] max-w-2xl mx-auto reveal reveal-delay-2">{t.howItWorks.subtitle}</p>
    </div>

    <!-- Interactive Navigation Tabs -->
    <div class="flex justify-center mb-16 reveal reveal-delay-3">
      <div class="relative flex p-1 bg-white border border-[#DCD3C5]/40 rounded-2xl shadow-sm">
        <!-- Sliding active background -->
        <div id="tab-slider" class="absolute top-1 bottom-1 left-1 w-[160px] md:w-[200px] bg-primary rounded-xl transition-all duration-300 ease-out z-0"></div>
        
        <button 
          id="btn-student" 
          class="relative z-10 w-[160px] md:w-[200px] py-3 text-sm font-bold text-white transition-colors duration-300 focus:outline-none"
        >
          {t.howItWorks.tabs.student}
        </button>
        <button 
          id="btn-institution" 
          class="relative z-10 w-[160px] md:w-[200px] py-3 text-sm font-bold text-[#44403C] hover:text-[#1F2523] transition-colors duration-300 focus:outline-none"
        >
          {t.howItWorks.tabs.institution}
        </button>
      </div>
    </div>

    <!-- Student Steps Grid -->
    <div id="flow-student" class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto transition-all duration-500 ease-out">
      {t.howItWorks.studentSteps.map((step, index) => (
        <div class="relative group bg-white rounded-2xl border border-[#DCD3C5]/40 p-8 reveal hover:-translate-y-1 hover:shadow-md hover:border-primary/20 transition-all duration-500 shadow-sm" style={`transition-delay: ${index * 0.1}s;`}>
          <!-- Background Step Number -->
          <div class="absolute -right-4 -bottom-6 font-display font-black text-9xl text-[#0F6B68]/[0.04] select-none pointer-events-none">
            {`0${index + 1}`}
          </div>
          
          <div class="relative z-10">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-[#0F6B68]/10 border border-[#0F6B68]/20 mb-6 group-hover:scale-110 transition-transform duration-500">
              <Fragment set:html={studentIcons[index]} />
            </div>
            <h3 class="font-display font-bold text-xl text-[#1F2523] mb-4">{step.title}</h3>
            <p class="text-sm text-[#44403C] leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Institution Steps Grid (Hidden by default) -->
    <div id="flow-institution" class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto hidden opacity-0 translate-y-4 transition-all duration-500 ease-out">
      {t.howItWorks.institutionSteps.map((step, index) => (
        <div class="relative group bg-white rounded-2xl border border-[#DCD3C5]/40 p-8 hover:-translate-y-1 hover:shadow-md hover:border-primary/20 transition-all duration-500 shadow-sm">
          <!-- Background Step Number -->
          <div class="absolute -right-4 -bottom-6 font-display font-black text-9xl text-[#0F6B68]/[0.04] select-none pointer-events-none">
            {`0${index + 1}`}
          </div>
          
          <div class="relative z-10">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-[#0F6B68]/10 border border-[#0F6B68]/20 mb-6 group-hover:scale-110 transition-transform duration-500">
              <Fragment set:html={institutionIcons[index]} />
            </div>
            <h3 class="font-display font-bold text-xl text-[#1F2523] mb-4">{step.title}</h3>
            <p class="text-sm text-[#44403C] leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Reveal Observer for scroll animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { 
      if (entry.isIntersecting) {
        entry.target.classList.add('visible'); 
      }
    });
  }, { threshold: 0.1 });
  
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

  // Tabs switching logic
  const btnStudent = document.getElementById('btn-student');
  const btnInstitution = document.getElementById('btn-institution');
  const flowStudent = document.getElementById('flow-student');
  const flowInstitution = document.getElementById('flow-institution');
  const tabSlider = document.getElementById('tab-slider');

  if (btnStudent && btnInstitution && flowStudent && flowInstitution && tabSlider) {
    btnStudent.addEventListener('click', () => {
      // Activar pestaña estudiante
      tabSlider.style.transform = 'translateX(0)';
      btnStudent.classList.remove('text-[#44403C]', 'hover:text-[#1F2523]');
      btnStudent.classList.add('text-white');
      btnInstitution.classList.remove('text-white');
      btnInstitution.classList.add('text-[#44403C]', 'hover:text-[#1F2523]');
      
      // Mostrar flujo estudiante con animaciones suaves
      flowInstitution.classList.add('opacity-0', 'translate-y-4');
      setTimeout(() => {
        flowInstitution.classList.add('hidden');
        flowStudent.classList.remove('hidden');
        // Pequeño timeout para permitir el renderizado antes de transicionar
        setTimeout(() => {
          flowStudent.classList.remove('opacity-0', 'translate-y-4');
        }, 50);
      }, 300);
    });

    btnInstitution.addEventListener('click', () => {
      // Activar pestaña institución
      const width = btnStudent.offsetWidth;
      tabSlider.style.transform = `translateX(${width}px)`;
      btnInstitution.classList.remove('text-[#44403C]', 'hover:text-[#1F2523]');
      btnInstitution.classList.add('text-white');
      btnStudent.classList.remove('text-white');
      btnStudent.classList.add('text-[#44403C]', 'hover:text-[#1F2523]');
      
      // Mostrar flujo institución con animaciones suaves
      flowStudent.classList.add('opacity-0', 'translate-y-4');
      setTimeout(() => {
        flowStudent.classList.add('hidden');
        flowInstitution.classList.remove('hidden');
        // Pequeño timeout para permitir el renderizado antes de transicionar
        setTimeout(() => {
          flowInstitution.classList.remove('opacity-0', 'translate-y-4');
        }, 50);
      }, 300);
    });
  }
</script>
