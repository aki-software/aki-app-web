---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { t } = Astro.props;
---

<section class="py-20 md:py-28 bg-bg relative" id="como-funciona">
  <div class="container">
    <!-- Section header -->
    <div class="text-center mb-16 lg:mb-24">
      <span class="inline-block px-4 py-1.5 rounded-full bg-primary-light text-xs font-semibold text-primary tracking-wide uppercase mb-4 reveal">
        Simple
      </span>
      <h2 class="font-display font-extrabold text-4xl sm:text-5xl lg:text-6xl text-text mb-4 reveal reveal-delay-1">
        {t.howItWorks.title}
      </h2>
      <p class="text-lg text-text-muted reveal reveal-delay-2">{t.howItWorks.subtitle}</p>
    </div>

    <!-- Vertical timeline — alternating sides -->
    <div class="relative max-w-4xl mx-auto">
      <!-- Center line -->
      <div class="absolute left-4 lg:left-1/2 top-0 bottom-0 w-px bg-border lg:-translate-x-px"></div>

      {t.howItWorks.steps.map((step, index) => {
        const icons = ['🃏', '📊', '📄'];
        const isLeft = index % 2 === 0;
        return (
          <div class={`relative flex items-start mb-16 last:mb-0 ${isLeft ? 'lg:flex-row' : 'lg:flex-row-reverse'} reveal`}>
            {/* Number circle */}
            <div class="absolute left-4 lg:left-1/2 w-8 h-8 rounded-full bg-primary border-4 border-bg flex items-center justify-center z-10 lg:-translate-x-1/2">
              <span class="text-xs font-bold text-surface">{index + 1}</span>
            </div>

            {/* Content */}
            <div class={`ml-14 lg:ml-0 lg:w-5/12 ${isLeft ? 'lg:pr-12 lg:text-right' : 'lg:pl-12'}`}>
              {/* Visual block */}
              <div class={`w-20 h-20 rounded-2xl flex items-center justify-center mb-4 ${
                index === 0 ? 'bg-primary-light' : index === 1 ? 'bg-secondary-light' : 'bg-tertiary/20'
              }`}>
                <span class="text-4xl">{icons[index]}</span>
              </div>

              <h3 class="font-display font-bold text-2xl text-text mb-2">{step.title}</h3>
              <p class="text-text-muted leading-relaxed">{step.desc}</p>
            </div>

            {/* Spacer for other side */}
            <div class="hidden lg:block lg:w-5/12"></div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
