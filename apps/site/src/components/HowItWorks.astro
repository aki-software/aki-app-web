---
const steps = [
  {
    number: '1',
    icon: '🃏',
    title: 'Deslizá cartas',
    description: 'Interfaz tipo Tinder: deslizá a la derecha si te interesa, a la izquierda si no.',
  },
  {
    number: '2',
    icon: '📊',
    title: 'Obtené tu perfil',
    description: 'Tu código Holland RIASEC + 13 categorías ocupacionales con afinidades.',
  },
  {
    number: '3',
    icon: '📄',
    title: 'Recibí tu reporte',
    description: 'PDF detallado con recomendaciones de carreras enviado a tu email.',
  },
];
---

<section class="py-20 md:py-24 bg-bg" id="como-funciona">
  <div class="container">
    <div class="text-center mb-14">
      <h2 class="font-display font-extrabold text-3xl sm:text-4xl text-text mb-4">
        Cómo funciona
      </h2>
      <p class="text-lg text-text-muted">
        3 pasos simples para descubrir tu camino
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-14">
      {steps.map((step, index) => (
        <div class="flex flex-col items-center text-center gap-5">
          <!-- Step number -->
          <div class="w-14 h-14 rounded-full bg-primary flex items-center justify-center">
            <span class="text-2xl font-extrabold text-surface">{step.number}</span>
          </div>

          <!-- Visual -->
          <div class="w-48 h-48 rounded-3xl bg-primary-light flex items-center justify-center">
            <span class="text-6xl">{step.icon}</span>
          </div>

          <!-- Text -->
          <h3 class="font-display font-bold text-xl text-text">{step.title}</h3>
          <p class="text-sm text-text-muted leading-relaxed max-w-xs">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
