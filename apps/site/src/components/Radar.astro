---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { locale } = Astro.props;
---

<section class="py-24 md:py-32 relative bg-dark-bg text-white overflow-hidden" id="metodologia">
  <!-- Soft Ambient Glow behind content -->
  <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-[600px] h-[600px] bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute top-1/2 right-1/4 -translate-y-1/2 w-[600px] h-[600px] bg-emerald-500/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="container relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">
      
      <!-- Premium Radar Visualization Card (Fixed SVG boundaries and label clipping) -->
      <div class="flex-1 relative w-full max-w-[460px] mx-auto lg:mx-0 reveal">
        <!-- Floating Outer Glow -->
        <div class="absolute -inset-1 bg-gradient-to-br from-primary via-emerald-500 to-primary rounded-[3rem] blur-xl opacity-20 group-hover:opacity-40 transition duration-1000"></div>
        
        <div class="relative bg-white/5 backdrop-blur-2xl border border-white/10 p-8 md:p-10 rounded-[3rem] shadow-[0_20px_50px_rgba(0,0,0,0.4)] overflow-hidden group">
          <!-- Animated Top Glow Inside Card -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-4/5 h-24 bg-primary/10 blur-[40px] pointer-events-none"></div>
          
          <svg viewBox="0 0 100 100" class="w-full h-auto drop-shadow-[0_0_20px_rgba(var(--primary-rgb),0.15)] overflow-visible">
            <defs>
              <!-- Primary Radar Fills -->
              <linearGradient id="radarFill" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="var(--primary, #8b5cf6)" stop-opacity="0.35" />
                <stop offset="100%" stop-color="#10b981" stop-opacity="0.35" />
              </linearGradient>
              <!-- Primary Radar Border -->
              <linearGradient id="radarStroke" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="var(--primary, #8b5cf6)" />
                <stop offset="100%" stop-color="#34d399" />
              </linearGradient>
              <!-- Grid Ring Glow Filter -->
              <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
                <feGaussianBlur stdDeviation="1.5" result="blur" />
                <feComposite in="SourceGraphic" in2="blur" operator="over" />
              </filter>
            </defs>

            <!-- Background Polygons (Radar Grid Rings scaled to Max R=36 to avoid clipping) -->
            <!-- 100% Ring -->
            <polygon points="50,14 81.2,32 81.2,68 50,86 18.8,68 18.8,32" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="0.75" />
            <!-- 75% Ring -->
            <polygon points="50,23 73.4,36.5 73.4,63.5 50,77 26.6,63.5 26.6,36.5" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="0.5" />
            <!-- 50% Ring -->
            <polygon points="50,32 65.6,41 65.6,59 50,68 34.4,59 34.4,41" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="0.5" />
            <!-- 25% Ring -->
            <polygon points="50,41 57.8,45.5 57.8,54.5 50,59 42.2,54.5 42.2,45.5" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="0.5" />
            
            <!-- Axis lines from center to outer ring -->
            <line x1="50" y1="50" x2="50" y2="14" stroke="rgba(255,255,255,0.08)" stroke-width="0.5" stroke-dasharray="1 1" />
            <line x1="50" y1="50" x2="81.2" y2="32" stroke="rgba(255,255,255,0.08)" stroke-width="0.5" stroke-dasharray="1 1" />
            <line x1="50" y1="50" x2="81.2" y2="68" stroke="rgba(255,255,255,0.08)" stroke-width="0.5" stroke-dasharray="1 1" />
            <line x1="50" y1="50" x2="50" y2="86" stroke="rgba(255,255,255,0.08)" stroke-width="0.5" stroke-dasharray="1 1" />
            <line x1="50" y1="50" x2="18.8" y2="68" stroke="rgba(255,255,255,0.08)" stroke-width="0.5" stroke-dasharray="1 1" />
            <line x1="50" y1="50" x2="18.8" y2="32" stroke="rgba(255,255,255,0.08)" stroke-width="0.5" stroke-dasharray="1 1" />

            <!-- The "Result" Shape (Animated Profile scaled to R=36 max) -->
            <polygon 
              points="50,17 73.4,36.5 63.9,58 50,80 31.8,60.5 39.6,44" 
              fill="url(#radarFill)" 
              stroke="url(#radarStroke)" 
              stroke-width="1.5"
              class="animate-pulse origin-center"
              style="animation-duration: 4s;"
            />

            <!-- Bright glowing vertices points -->
            <circle cx="50" cy="17" r="1.5" fill="#a78bfa" filter="url(#glow)" />
            <circle cx="73.4" cy="36.5" r="1.5" fill="#60a5fa" filter="url(#glow)" />
            <circle cx="63.9" cy="58" r="1.5" fill="#34d399" filter="url(#glow)" />
            <circle cx="50" cy="80" r="1.5" fill="#f43f5e" filter="url(#glow)" />
            <circle cx="31.8" cy="60.5" r="1.5" fill="#f59e0b" filter="url(#glow)" />
            <circle cx="39.6" cy="44" r="1.5" fill="#e2e8f0" filter="url(#glow)" />

            <!-- Dynamic labels (RIASEC letters positioned safely to avoid edge clipping) -->
            <!-- R -->
            <text x="50" y="8" text-anchor="middle" fill="#a78bfa" font-size="6.5" font-weight="900" font-family="Sora, sans-serif">R</text>
            <!-- I -->
            <text x="87" y="29" text-anchor="start" fill="#60a5fa" font-size="6.5" font-weight="900" font-family="Sora, sans-serif">I</text>
            <!-- A -->
            <text x="87" y="73" text-anchor="start" fill="#34d399" font-size="6.5" font-weight="900" font-family="Sora, sans-serif">A</text>
            <!-- S -->
            <text x="50" y="93" text-anchor="middle" fill="#f43f5e" font-size="6.5" font-weight="900" font-family="Sora, sans-serif">S</text>
            <!-- E -->
            <text x="13" y="73" text-anchor="end" fill="#f59e0b" font-size="6.5" font-weight="900" font-family="Sora, sans-serif">E</text>
            <!-- C -->
            <text x="13" y="29" text-anchor="end" fill="#e2e8f0" font-size="6.5" font-weight="900" font-family="Sora, sans-serif">C</text>
          </svg>
        </div>
      </div>

      <!-- RIASEC Information and Descriptions -->
      <div class="flex-1 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 backdrop-blur-md mb-6 reveal reveal-delay-1 shadow-[0_0_15px_rgba(255,255,255,0.05)]">
          <p class="text-[11px] font-medium text-emerald-400 tracking-widest uppercase">
            CIENCIA Y ORIENTACIÓN
          </p>
        </div>
        <h2 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl text-white mb-6 reveal reveal-delay-1 tracking-tight">
          {locale === 'es' ? 'Tu perfil en 6 dimensiones' : 'Your profile in 6 dimensions'}
        </h2>
        <p class="text-lg text-dark-muted leading-relaxed mb-10 reveal reveal-delay-2 max-w-2xl mx-auto lg:mx-0">
          {locale === 'es' 
            ? 'A.kit mapea tus intereses mediante un enfoque científico de orientación vocacional validado globalmente. Identificamos tu afinidad en seis áreas clave de personalidad ocupacional para trazar el mapa de tu futuro.'
            : 'A.kit maps your interests using a globally validated scientific approach in vocational guidance. We identify your affinity across six key areas of occupational personality to chart your future.'}
        </p>

        <!-- RIASEC Legend Grid with Modern Micro-Interactions -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 reveal reveal-delay-3">
          {[
            { letter: 'R', label: locale === 'es' ? 'Realista' : 'Realistic', desc: locale === 'es' ? 'Hacer y construir' : 'Do & Build', color: 'border-violet-500/20 text-violet-400 bg-violet-500/10 hover:border-violet-500/50' },
            { letter: 'I', label: locale === 'es' ? 'Investigativo' : 'Investigative', desc: locale === 'es' ? 'Pensar y analizar' : 'Think & Analyze', color: 'border-blue-500/20 text-blue-400 bg-blue-500/10 hover:border-blue-500/50' },
            { letter: 'A', label: locale === 'es' ? 'Artístico' : 'Artistic', desc: locale === 'es' ? 'Crear y diseñar' : 'Create & Design', color: 'border-emerald-500/20 text-emerald-400 bg-emerald-500/10 hover:border-emerald-500/50' },
            { letter: 'S', label: locale === 'es' ? 'Social' : 'Social', desc: locale === 'es' ? 'Ayudar y enseñar' : 'Help & Teach', color: 'border-rose-500/20 text-rose-400 bg-rose-500/10 hover:border-rose-500/50' },
            { letter: 'E', label: locale === 'es' ? 'Emprendedor' : 'Enterprising', desc: locale === 'es' ? 'Liderar e influir' : 'Lead & Influence', color: 'border-amber-500/20 text-amber-400 bg-amber-500/10 hover:border-amber-500/50' },
            { letter: 'C', label: locale === 'es' ? 'Convencional' : 'Conventional', desc: locale === 'es' ? 'Organizar y estructurar' : 'Organize & Structure', color: 'border-slate-400/20 text-slate-300 bg-slate-400/10 hover:border-slate-400/50' },
          ].map((type) => (
            <div class={`group flex items-center gap-3.5 p-3.5 rounded-2xl bg-white/5 border backdrop-blur-md transition-all duration-300 hover:-translate-y-1 ${type.color} shadow-[0_4px_12px_rgba(0,0,0,0.15)]`}>
              <div class="w-8 h-8 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center font-display font-black text-sm group-hover:scale-110 transition-transform duration-300 shadow-sm">
                <span>{type.letter}</span>
              </div>
              <div class="text-left">
                <p class="text-sm font-bold text-white leading-none mb-1">{type.label}</p>
                <p class="text-[10px] text-dark-muted font-medium uppercase tracking-wider leading-none">{type.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { 
      if (entry.isIntersecting) {
        entry.target.classList.add('visible'); 
      }
    });
  }, { threshold: 0.1 });
  
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
