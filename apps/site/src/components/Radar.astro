---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { locale, t } = Astro.props;
const categories = t.methodology.categories;

interface BadgeStyle {
  code: string;
  border: string;
  text: string;
  bg: string;
  dot: string;
}

const badgeStyles: BadgeStyle[] = [
  { code: 'ART', border: 'border-violet-200', text: 'text-violet-700', bg: 'bg-violet-50', dot: '#a78bfa' },
  { code: 'HUM', border: 'border-fuchsia-200', text: 'text-fuchsia-700', bg: 'bg-fuchsia-50', dot: '#d946ef' },
  { code: 'SERV', border: 'border-teal-200', text: 'text-teal-700', bg: 'bg-teal-50', dot: '#0d9488' },
  { code: 'PROT', border: 'border-slate-200', text: 'text-slate-700', bg: 'bg-slate-50', dot: '#64748b' },
  { code: 'FÍS', border: 'border-red-200', text: 'text-red-700', bg: 'bg-red-50', dot: '#f43f5e' },
  { code: 'IND', border: 'border-zinc-200', text: 'text-zinc-700', bg: 'bg-zinc-50', dot: '#52525b' },
  { code: 'MEC', border: 'border-orange-200', text: 'text-orange-700', bg: 'bg-orange-50', dot: '#ea580c' },
  { code: 'NAT', border: 'border-green-200', text: 'text-green-700', bg: 'bg-green-50', dot: '#22c55e' },
  { code: 'LÍD', border: 'border-indigo-200', text: 'text-indigo-700', bg: 'bg-indigo-50', dot: '#6366f1' },
  { code: 'SCI', border: 'border-indigo-300', text: 'text-indigo-800', bg: 'bg-indigo-100', dot: '#4338ca' },
  { code: 'VENT', border: 'border-red-200', text: 'text-red-700', bg: 'bg-red-50', dot: '#f43f5e' },
  { code: 'BUS', border: 'border-indigo-200', text: 'text-indigo-800', bg: 'bg-indigo-50', dot: '#312e81' },
];
---

<section class="py-24 md:py-32 relative bg-[#F5EFE7] overflow-hidden" id="metodologia">
  <div class="container relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">
      <!-- Radar Visualization Card -->
      <div class="flex-1 relative w-full max-w-[460px] mx-auto lg:mx-0">
        <div id="radar-card" class="bg-white border border-[#DCD3C5]/40 p-8 md:p-10 rounded-[3rem] shadow-md overflow-hidden">
          <div class="radar-svg-wrapper" style="transform: scale(0.8); opacity: 0; transition: transform 1s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.6s ease;">
            <svg aria-hidden="true" viewBox="0 0 100 100" class="w-full h-auto overflow-visible">
              <defs>
                <linearGradient id="radarFillRecharts" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="5%" stop-color="var(--color-primary)" stop-opacity="0.55" />
                  <stop offset="95%" stop-color="var(--color-primary)" stop-opacity="0.08" />
                </linearGradient>
                <filter id="dot-glow-recharts">
                  <feGaussianBlur stdDeviation="1" result="blur"/>
                  <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
              </defs>

              <!-- Polar grid: concentric circles at 25%, 50%, 75%, 100% -->
              <circle cx="50" cy="50" r="36" fill="none" stroke="rgba(0,0,0,0.10)" stroke-width="0.4" />
              <circle cx="50" cy="50" r="27" fill="none" stroke="rgba(0,0,0,0.06)" stroke-width="0.3" stroke-dasharray="2 2" />
              <circle cx="50" cy="50" r="18" fill="none" stroke="rgba(0,0,0,0.05)" stroke-width="0.3" stroke-dasharray="2 2" />
              <circle cx="50" cy="50" r="9" fill="none" stroke="rgba(0,0,0,0.04)" stroke-width="0.3" stroke-dasharray="1.5 1.5" />

              <!-- Radius axis lines (dashed) -->
              {[
                [50, 14], [68, 18.8], [81.2, 32], [86, 50],
                [81.2, 68], [68, 81.2], [50, 86], [32, 81.2],
                [18.8, 68], [14, 50], [18.8, 32], [32, 18.8]
              ].map(([x1, y1]) => (
                <line x1={`${x1}`} y1={`${y1}`} x2="50" y2="50" stroke="rgba(0,0,0,0.07)" stroke-width="0.3" stroke-dasharray="2 3" />
              ))}

              <!-- Radius axis labels (0, 25, 50, 75, 100) on the right axis -->
              {[
                { x: 50, y: 91, val: '0' },
                { x: 41, y: 83, val: '25' },
                { x: 32, y: 74, val: '50' },
                { x: 23, y: 65, val: '75' },
                { x: 14, y: 56, val: '100' }
              ].map(({ x, y, val }) => (
                <text x={`${x}`} y={`${y}`} text-anchor="end" fill="rgba(0,0,0,0.15)" font-size="2.2" font-weight="500" font-family="monospace">{val}</text>
              ))}

              <!-- Result polygon (animated draw) -->
              <polygon id="radar-result"
                points="50,20 63,25 72,35 78,50 72,60 62,72 50,78 38,72 28,60 24,50 28,38 38,25"
                fill="url(#radarFillRecharts)"
                stroke="var(--color-primary)"
                stroke-width="1.8"
                stroke-linejoin="round"
                stroke-dasharray="400"
                stroke-dashoffset="400"
                filter="url(#dot-glow-recharts)"
              />

              <!-- Vertex dots on result polygon -->
              {[
                { x: 50, y: 20, color: '#a78bfa', code: 'ART' },
                { x: 63, y: 25, color: '#d946ef', code: 'HUM' },
                { x: 72, y: 35, color: '#0d9488', code: 'SERV' },
                { x: 78, y: 50, color: '#64748b', code: 'PROT' },
                { x: 72, y: 60, color: '#f43f5e', code: 'FÍS' },
                { x: 62, y: 72, color: '#52525b', code: 'IND' },
                { x: 50, y: 78, color: '#ea580c', code: 'MEC' },
                { x: 38, y: 72, color: '#22c55e', code: 'NAT' },
                { x: 28, y: 60, color: '#6366f1', code: 'LÍD' },
                { x: 24, y: 50, color: '#4338ca', code: 'SCI' },
                { x: 28, y: 38, color: '#f43f5e', code: 'VENT' },
                { x: 38, y: 25, color: '#312e81', code: 'BUS' }
              ].map(({ x, y, color, code }) => (
                <circle id={`v-${code}`}
                  cx={`${x}`} cy={`${y}`} r="3" fill={color} stroke="white" stroke-width="1" filter="url(#dot-glow-recharts)"
                  class="radar-dot-recharts" />
              ))}

              <!-- Category labels (codes with full names below) -->
              {[
                { x: 50, y: 6, code: 'ART', fullName: 'Artística', color: '#7c3aed' },
                { x: 70, y: 16, code: 'HUM', fullName: 'Humanidades', color: '#c026d3' },
                { x: 86, y: 30, code: 'SERV', fullName: 'Servicio Social', color: '#0f766e' },
                { x: 91, y: 50, code: 'PROT', fullName: 'Protección', color: '#475569' },
                { x: 86, y: 70, code: 'FÍS', fullName: 'Deportes', color: '#dc2626' },
                { x: 70, y: 84, code: 'IND', fullName: 'Industria', color: '#525252' },
                { x: 50, y: 92, code: 'MEC', fullName: 'Mecánica', color: '#c2410c' },
                { x: 30, y: 84, code: 'NAT', fullName: 'Naturaleza', color: '#16a34a' },
                { x: 14, y: 70, code: 'LÍD', fullName: 'Liderazgo', color: '#4f46e5' },
                { x: 9, y: 50, code: 'SCI', fullName: 'Ciencia', color: '#3730a3' },
                { x: 14, y: 30, code: 'VENT', fullName: 'Ventas', color: '#dc2626' },
                { x: 30, y: 16, code: 'BUS', fullName: 'Negocios', color: '#1e1b4b' }
              ].map(({ x, y, code, fullName, color }) => {
                const isLeft = x < 50;
                const anchor = x === 50 ? 'middle' : isLeft ? 'end' : 'start';
                const labelX = x === 50 ? x : isLeft ? x - 3 : x + 3;
                return (
                  <g>
                    <text x={`${labelX}`} y={`${y}`} text-anchor={anchor} fill={color} font-size="4.2" font-weight="800" font-family="Sora, sans-serif" letter-spacing="1.5">{code}</text>
                    <text x={`${labelX}`} y={`${y + 4.5}`} text-anchor={anchor} fill="rgba(0,0,0,0.35)" font-size="2.5" font-weight="500" font-family="Sora, sans-serif">{fullName}</text>
                  </g>
                );
              })}
            </svg>
          </div>
        </div>
      </div>

      <!-- Right: Description + Interactive Badge Grid -->
      <div class="flex-1 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-[#8E5A12]/20 mb-6 reveal reveal-delay-1 shadow-sm">
          <p class="text-[11px] font-medium text-[#8E5A12] tracking-widest uppercase">
            METODOLOGÍA CIENTÍFICA
          </p>
        </div>
        <h2 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl text-[#1F2523] mb-6 reveal reveal-delay-1 tracking-tight">
          {locale === 'es' ? '12 categorías ocupacionales' : '12 occupational categories'}
        </h2>
        <p class="text-lg text-[#44403C] leading-relaxed mb-10 reveal reveal-delay-2 max-w-2xl mx-auto lg:mx-0">
          {locale === 'es'
            ? 'A.ki mapea tus intereses mediante un enfoque científico de orientación vocacional validado globalmente. Identificamos tu afinidad en doce categorías ocupacionales para trazar el mapa de tu futuro.'
            : 'A.ki maps your interests using a globally validated scientific approach in vocational guidance. We identify your affinity across twelve occupational categories to chart your future.'}
        </p>

        <!-- Interactive badge grid -->
        <div id="badge-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2 reveal reveal-delay-3">
          {badgeStyles.map((type) => {
            const cat = categories.find((c) => c.code === type.code);
            return (
              <button
                data-code={type.code}
                data-fullname={cat?.name || type.code}
                class={`badge-chip flex items-center gap-2 p-2 rounded-xl bg-white border shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md ${type.border}`}
              >
                <span class={`w-2 h-2 rounded-full flex-shrink-0 ${type.bg} border ${type.border}`} style={`background: ${type.dot}`}></span>
                <span class={`font-display font-bold text-xs tracking-wider ${type.text}`}>{type.code}</span>
              </button>
            );
          })}
        </div>

        <!-- Active category tooltip -->
        <div id="cat-tooltip" class="mt-6 text-center text-sm text-[#44403C] min-h-[1.5rem] transition-opacity duration-300 opacity-0">
          {locale === 'es' ? 'Pasá el cursor sobre una categoría' : 'Hover over a category'}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .radar-dot-recharts {
    transition: r 0.25s ease, filter 0.25s ease;
    cursor: default;
  }
  .radar-dot-recharts.active {
    r: 5;
    filter: drop-shadow(0 0 6px currentColor);
  }
  .radar-result-animate {
    animation: radar-draw 1s ease-out forwards;
  }
  @keyframes radar-draw {
    to { stroke-dashoffset: 0; }
  }
</style>

<script>
  const radarCard = document.getElementById('radar-card');
  const svgWrapper = document.querySelector('.radar-svg-wrapper') as HTMLElement | null;
  const tooltip = document.getElementById('cat-tooltip');
  const chips = document.querySelectorAll<HTMLButtonElement>('.badge-chip');

  // Scroll-triggered radar animation
  const radarObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting && svgWrapper) {
        svgWrapper.style.transform = 'scale(1)';
        svgWrapper.style.opacity = '1';
        const poly = document.getElementById('radar-result');
        if (poly) poly.classList.add('radar-result-animate');
        radarObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });
  if (radarCard) radarObserver.observe(radarCard);

  // Badge hover → highlight dot
  chips.forEach((chip) => {
    chip.addEventListener('mouseenter', () => {
      const code = chip.dataset.code;
      const dot = document.querySelector(`.radar-dot-recharts[id="v-${code}"]`);
      if (dot) dot.classList.add('active');
      if (tooltip) {
        tooltip.textContent = chip.dataset.fullname || code || '';
        tooltip.style.opacity = '1';
      }
    });
    chip.addEventListener('mouseleave', () => {
      document.querySelectorAll('.radar-dot-recharts').forEach((v) => v.classList.remove('active'));
      if (tooltip) {
        tooltip.style.opacity = '0';
      }
    });
  });

  // Standard reveal observer for other elements
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
</script>