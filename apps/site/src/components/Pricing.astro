---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { locale, t } = Astro.props;
const playStoreUrl = import.meta.env.PUBLIC_PLAY_STORE_URL || 'https://play.google.com/store/apps/details?id=com.akit.app';

const isEn = locale === 'en';
const freeMailto = `mailto:contacto@orientaki.com?subject=${encodeURIComponent(isEn ? 'A.ki Pilot Access Request' : 'Solicitud Acceso A.ki Piloto')}`;
const premiumMailto = `mailto:contacto@orientaki.com?subject=${encodeURIComponent(isEn ? 'A.ki Campus Plan Consultation' : 'Consulta Plan A.ki Campus')}`;
---

<section class="py-24 md:py-32 relative bg-dark-bg overflow-hidden" id="precios">
  <!-- Background Glows -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="container relative z-10">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 backdrop-blur-md mb-6 reveal shadow-[0_0_15px_rgba(255,255,255,0.05)]">
        <p class="text-[11px] font-medium text-emerald-400 tracking-widest uppercase">
          PLANES CLAROS
        </p>
      </div>
      <h2 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl text-white mb-6 reveal reveal-delay-1 tracking-tight">{t.pricing.title}</h2>
      <p class="text-lg text-dark-muted max-w-2xl mx-auto reveal reveal-delay-2">{t.pricing.subtitle}</p>
    </div>

    <div class="flex flex-col md:flex-row items-stretch justify-center gap-6 lg:gap-8 max-w-5xl mx-auto">
      <!-- Free Tier -->
      <div class="w-full md:w-[340px] flex flex-col bg-white/5 backdrop-blur-xl rounded-[2rem] border border-white/10 p-8 reveal hover:-translate-y-2 transition-transform duration-500 shadow-[0_8px_30px_rgba(0,0,0,0.2)]">
        <div class="mb-8">
          <p class="text-sm font-semibold text-white/60 uppercase tracking-widest mb-4">{t.pricing.free.label}</p>
          <div class="flex items-baseline gap-1">
            <span class="font-display font-bold text-5xl text-white">$0</span>
          </div>
        </div>
        
        <div class="flex-1 flex flex-col gap-4 mb-8">
          {t.pricing.free.features.map((f) => (
            <div class="flex items-start gap-3">
              <div class="mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-white/10 flex items-center justify-center">
                <svg class="w-3 h-3 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-sm text-white/80 leading-relaxed">{f}</span>
            </div>
          ))}
        </div>

          <a href={freeMailto} class="mt-auto block w-full py-4 text-center text-sm font-bold text-white bg-white/10 border border-white/20 rounded-xl hover:bg-white/20 transition-colors">
            {t.pricing.free.cta}
          </a>
        </div>

        <!-- Premium Tier (Highlighted) -->
        <div class="relative w-full md:w-[380px] flex flex-col bg-gradient-to-b from-dark-surface to-dark-bg rounded-[2rem] p-1 reveal reveal-delay-1 hover:-translate-y-2 transition-transform duration-500 shadow-[0_20px_40px_rgba(var(--primary-rgb),0.15)] group">
          <!-- Animated Gradient Border -->
          <div class="absolute inset-0 rounded-[2rem] bg-gradient-to-br from-primary via-emerald-400 to-primary opacity-50 group-hover:opacity-100 transition-opacity duration-500" style="mask-image: linear-gradient(black, black); mask-composite: exclude;"></div>
          
          <div class="relative h-full flex flex-col bg-dark-bg/90 backdrop-blur-2xl rounded-[1.9rem] p-8 overflow-hidden">
            <!-- Top Glow -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-32 bg-primary/20 blur-[50px] pointer-events-none"></div>

            <div class="relative mb-8">
              <div class="flex justify-between items-center mb-4">
                <p class="text-sm font-semibold text-primary-light uppercase tracking-widest">{t.pricing.premium.label}</p>
                <span class="px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-dark-bg bg-gradient-to-r from-primary to-emerald-400 rounded-full shadow-[0_0_10px_rgba(var(--primary-rgb),0.5)]">
                  {t.pricing.premium.badge}
                </span>
              </div>
              <div class="flex items-baseline gap-1 mb-2">
                <span class="font-display font-bold text-5xl text-transparent bg-clip-text bg-gradient-to-r from-white to-white/70">{t.pricing.premium.price}</span>
              </div>
              <p class="text-xs text-white/50 font-medium">{t.pricing.premium.desc}</p>
            </div>
            
            <div class="flex-1 flex flex-col gap-4 mb-8 relative">
              {t.pricing.premium.features.map((f) => (
                <div class="flex items-start gap-3">
                  <div class="mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-primary/20 border border-primary/30 flex items-center justify-center">
                    <svg class="w-3 h-3 text-primary-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="text-sm text-white leading-relaxed">{f}</span>
                </div>
              ))}
            </div>

            <a href={premiumMailto} class="relative mt-auto block w-full py-4 text-center text-sm font-bold text-dark-bg bg-white rounded-xl hover:scale-[1.02] transition-transform shadow-[0_0_20px_rgba(255,255,255,0.2)] overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-primary to-primary-light opacity-0 hover:opacity-10 transition-opacity"></div>
              {t.pricing.premium.cta}
            </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
