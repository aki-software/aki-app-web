---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { t } = Astro.props;
const playStoreUrl = import.meta.env.PUBLIC_PLAY_STORE_URL || 'https://play.google.com/store/apps/details?id=com.akit.app';
---

<section class="py-20 md:py-24 bg-bg" id="precios">
  <div class="container">
    <div class="text-center mb-14">
      <h2 class="font-display font-extrabold text-3xl sm:text-4xl text-text mb-4">
        {t.pricing.title}
      </h2>
      <p class="text-lg text-text-muted">
        {t.pricing.subtitle}
      </p>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-center gap-6 lg:gap-8">
      <!-- Free Plan -->
      <div class="w-full md:w-[340px] bg-surface rounded-3xl border border-border p-9 flex flex-col gap-5">
        <span class="text-sm font-semibold text-text-muted">{t.pricing.free.label}</span>
        <span class="font-display font-extrabold text-5xl text-text">$0</span>

        <div class="flex flex-col gap-3 pt-2">
          {t.pricing.free.features.map((feature) => (
            <div class="flex items-center gap-2">
              <span class="text-tertiary font-bold">✓</span>
              <span class="text-sm text-text">{feature}</span>
            </div>
          ))}
        </div>

        <a
          href={playStoreUrl}
          class="mt-2 w-full py-3 text-center text-sm font-bold text-surface bg-primary rounded-xl hover:bg-primary-dark transition-colors"
        >
          {t.pricing.free.cta}
        </a>
      </div>

      <!-- Premium Plan -->
      <div class="w-full md:w-[380px] bg-primary rounded-3xl border-2 border-primary p-9 flex flex-col gap-5 relative">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
          <span class="px-3 py-1 bg-primary-light text-primary text-xs font-bold rounded-full">
            {t.pricing.premium.badge}
          </span>
        </div>

        <span class="text-sm font-semibold text-primary-light">{t.pricing.premium.label}</span>
        <span class="font-display font-extrabold text-4xl text-surface">{t.pricing.premium.price}</span>
        <span class="text-sm text-primary-light">{t.pricing.premium.desc}</span>

        <div class="flex flex-col gap-3 pt-2">
          {t.pricing.premium.features.map((feature) => (
            <div class="flex items-center gap-2">
              <span class="text-primary-light font-bold">✓</span>
              <span class="text-sm text-surface">{feature}</span>
            </div>
          ))}
        </div>

        <a
          href={playStoreUrl}
          class="mt-2 w-full py-3 text-center text-sm font-bold text-primary bg-surface rounded-xl hover:bg-primary-light transition-colors"
        >
          {t.pricing.premium.cta}
        </a>
      </div>
    </div>
  </div>
</section>
