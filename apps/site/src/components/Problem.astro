---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { t } = Astro.props;
---

<section class="py-20 md:py-28 bg-primary-dark overflow-hidden" id="problema">
  <div class="container mb-12">
    <h2 class="font-display font-extrabold text-3xl sm:text-4xl lg:text-5xl text-dark-text text-center reveal">
      {t.problem.title}
    </h2>
  </div>

  <!-- Marquee with pain points -->
  <div class="relative">
    <div class="flex animate-marquee">
      <!-- First set -->
      {t.problem.cards.map((card, i) => {
        const icons = ['🎓', '😴', '💰'];
        return (
          <div class="flex-shrink-0 mx-4 px-8 py-6 bg-dark-surface/50 border border-dark-border rounded-2xl backdrop-blur-sm" style="width: 380px;">
            <div class="flex items-center gap-4">
              <span class="text-3xl">{icons[i]}</span>
              <div>
                <p class="font-display font-bold text-dark-text text-lg">{card.title}</p>
                <p class="text-sm text-dark-muted mt-1">{card.desc}</p>
              </div>
            </div>
          </div>
        );
      })}
      <!-- Duplicate set for seamless loop -->
      {t.problem.cards.map((card, i) => {
        const icons = ['🎓', '😴', '💰'];
        return (
          <div class="flex-shrink-0 mx-4 px-8 py-6 bg-dark-surface/50 border border-dark-border rounded-2xl backdrop-blur-sm" style="width: 380px;">
            <div class="flex items-center gap-4">
              <span class="text-3xl">{icons[i]}</span>
              <div>
                <p class="font-display font-bold text-dark-text text-lg">{card.title}</p>
                <p class="text-sm text-dark-muted mt-1">{card.desc}</p>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Big statement -->
  <div class="container mt-16 text-center reveal">
    <p class="text-xl md:text-2xl text-dark-muted font-medium max-w-2xl mx-auto">
      <span class="text-primary-light font-semibold">No tiene que ser así.</span>
      {t.locale === 'es' ? ' Creamos ORIENT A.KI para que elegir tu camino sea simple, visual y hasta divertido.' : ' We created ORIENT A.KI to make choosing your path simple, visual and even fun.'}
    </p>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
