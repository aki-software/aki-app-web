---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { t } = Astro.props;
---

<section class="py-20 md:py-24 bg-primary-light" id="problema">
  <div class="container">
    <h2 class="font-display font-extrabold text-3xl sm:text-4xl text-text text-center mb-14">
      {t.problem.title}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {t.problem.cards.map((card, i) => {
        const icons = ['🎓', '😴', '💰'];
        return (
          <div class="bg-surface rounded-3xl p-8 flex flex-col gap-4 shadow-sm">
            <div class="w-12 h-12 rounded-2xl bg-secondary-light flex items-center justify-center">
              <span class="text-2xl">{icons[i]}</span>
            </div>
            <h3 class="font-display font-bold text-lg text-text">{card.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{card.desc}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
