---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { t } = Astro.props;
const webUrl = import.meta.env.PUBLIC_WEB_URL || 'http://localhost:5173';
const playStoreUrl = import.meta.env.PUBLIC_PLAY_STORE_URL || 'https://play.google.com/store/apps/details?id=com.akit.app';
---

<section class="py-16 md:py-24 bg-bg" id="cta-final">
  <div class="container text-center">
    <h2 class="font-display font-bold text-2xl md:text-3xl lg:text-4xl text-text mb-4 reveal">
      {t.finalCta.title}
    </h2>
    <p class="text-text-muted mb-8 max-w-md mx-auto reveal reveal-delay-1">
      {t.finalCta.subtitle}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-8 reveal reveal-delay-2">
      <a href={playStoreUrl} class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-surface bg-primary rounded-lg hover:bg-primary-dark transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 010 1.38l-2.302 2.302L15.396 12l2.302-2.492zM5.864 2.658L16.8 8.99l-2.302 2.302L5.864 2.658z"/>
        </svg>
        {t.finalCta.googlePlay}
      </a>
      <a href={webUrl} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-medium text-text-muted hover:text-primary transition-colors">
        {t.finalCta.webVersion}
      </a>
    </div>

    <!-- QR -->
    <div class="flex items-center justify-center gap-3 reveal reveal-delay-3">
      <div class="w-16 h-16 rounded-lg bg-surface border border-border flex items-center justify-center p-2">
        <img src="/qr-playstore.svg" alt={t.finalCta.qrLabel} class="w-full h-full object-contain rounded" loading="lazy" />
      </div>
      <div class="text-left">
        <p class="text-sm font-medium text-text">{t.finalCta.qrLabel}</p>
        <p class="text-xs text-text-muted">{t.finalCta.qrSublabel}</p>
      </div>
    </div>
  </div>
</section>

<!-- Sticky mobile CTA -->
<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-surface/95 backdrop-blur-sm border-t border-border p-3">
  <a href={playStoreUrl} class="flex items-center justify-center gap-2 w-full py-3 text-sm font-semibold text-surface bg-primary rounded-lg">
    {t.finalCta.googlePlay} — {t.pricing.free.label}
  </a>
</div>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
