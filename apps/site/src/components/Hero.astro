---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { t, locale } = Astro.props;
const playStoreUrl = import.meta.env.PUBLIC_PLAY_STORE_URL || 'https://play.google.com/store/apps/details?id=com.akit.app';
const dashboardUrl = import.meta.env.PUBLIC_DASHBOARD_URL || 'http://localhost:5173/';
const cardData = t.hero.cards;
---

<section class="min-h-screen flex flex-col justify-center bg-dark-bg text-dark-text relative overflow-hidden" id="hero">
  <div class="container relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
      <!-- Left: Bold typography + CTA -->
      <div class="flex-1 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 backdrop-blur-md mb-8 reveal shadow-[0_0_15px_rgba(255,255,255,0.05)]">
          <p class="text-[11px] font-medium text-white/80 tracking-widest uppercase">
            {t.hero.badge}
          </p>
        </div>

        <h1 class="font-display font-bold text-5xl sm:text-6xl md:text-7xl lg:text-[5rem] leading-[1.05] tracking-tight mb-6 reveal reveal-delay-1">
          {t.hero.title}<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-primary-light to-confirm">
            {t.hero.titleAccent}
          </span>
        </h1>

        <p class="text-lg text-dark-muted leading-relaxed max-w-xl mx-auto lg:mx-0 mb-10 reveal reveal-delay-2 font-medium">
          {t.hero.subtitle}
        </p>

        <div class="flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start reveal reveal-delay-3">
          <a href={playStoreUrl} class="group relative w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 text-sm font-semibold text-dark-bg bg-white rounded-xl hover:scale-105 transition-all duration-300 shadow-[0_0_30px_rgba(255,255,255,0.3)]">
            <div class="absolute inset-0 rounded-xl bg-gradient-to-r from-primary to-primary-light opacity-0 group-hover:opacity-10 transition-opacity"></div>
            <svg aria-hidden="true" class="w-5 h-5 text-dark-bg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 010 1.38l-2.302 2.302L15.396 12l2.302-2.492zM5.864 2.658L16.8 8.99l-2.302 2.302L5.864 2.658z"/>
            </svg>
            {t.hero.ctaPrimary}
          </a>
          <a href="#instituciones" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-sm font-semibold text-white bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:border-white/20 backdrop-blur-md transition-all duration-300">
            {t.hero.ctaSecondary}
          </a>
        </div>

        <p class="text-xs text-dark-muted/60 mt-6 reveal reveal-delay-3 font-mono">
          {locale === 'es' ? 'APP MÓVIL · SIN REGISTRO · TEST DINÁMICO' : 'MOBILE APP · NO SIGNUP · DYNAMIC TEST'}
        </p>
      </div>

      <!-- Right: Phone mockup with carousel -->
      <div class="flex-shrink-0 w-full max-w-sm lg:max-w-none lg:w-[400px] reveal reveal-delay-2 mt-12 lg:mt-0">
        <div class="h-[520px] bg-gradient-to-br from-white/10 to-white/5 border border-white/20 rounded-[40px] p-8 shadow-[0_30px_60px_rgba(0,0,0,0.4)] backdrop-blur-2xl flex flex-col overflow-hidden">
          <!-- App UI Header Mockup -->
          <div class="flex justify-between items-center flex-shrink-0 mb-6">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-primary"></div>
              <span class="text-[10px] font-mono tracking-widest text-white/40 uppercase">A.KI - Orient</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-[10px] font-mono text-white/50">{t.hero.phoneProgress}</span>
              <div class="w-16 h-1.5 bg-white/10 rounded-full overflow-hidden border border-white/5">
                <div class="w-[30%] h-full bg-gradient-to-r from-primary to-primary-light rounded-full"></div>
              </div>
            </div>
          </div>

          <!-- Phone Instruction Title -->
          <div class="text-center flex-shrink-0 mb-4">
            <span class="text-[11px] font-bold text-white/40 uppercase tracking-widest">{t.hero.phoneTitle}</span>
          </div>

          <!-- Card sorting space -->
          <div class="flex-1 min-h-0 relative mb-6">
            <div class="absolute w-[94%] h-[94%] top-[3%] left-[3%] bg-white/5 border border-white/10 rounded-3xl -rotate-3 scale-95 opacity-40 blur-[0.5px]"></div>

            <!-- Active sorting Card -->
            <div class="absolute inset-0 bg-gradient-to-br from-white/10 to-white/5 border border-white/20 rounded-3xl p-6 flex flex-col justify-between shadow-[0_15px_30px_rgba(0,0,0,0.3)] backdrop-blur-md overflow-hidden group/card hover:border-primary/50 transition-all duration-500">
              <div class="absolute top-0 right-0 w-16 h-16 bg-primary/20 rounded-full blur-xl opacity-60 pointer-events-none"></div>

              <div class="flex justify-between items-start flex-shrink-0">
                <span id="card-badge" class="text-[9px] font-bold tracking-wider px-2 py-0.5 rounded bg-primary/20 text-primary-light border border-primary/30 uppercase">
                  {cardData[0].code}
                </span>
                <div class="flex gap-1 items-center opacity-60">
                  <svg aria-hidden="true" class="w-3.5 h-3.5 text-white/40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
                  </svg>
                </div>
              </div>

              <div class="flex-1 min-h-0 flex items-center justify-center my-3 overflow-hidden rounded-2xl relative">
                {cardData.map((card, i) => (
                  <img
                    src={card.image}
                    alt=""
                    data-code={card.code}
                    class="card-slide absolute inset-0 w-full h-full object-cover rounded-2xl transition-opacity duration-500"
                    style={`opacity: ${i === 0 ? 1 : 0}; ${i > 0 ? 'pointer-events: none;' : ''}`}
                  />
                ))}
              </div>
            </div>
          </div>

          <!-- Carousel dots -->
          <div class="flex items-center justify-center gap-2 flex-shrink-0 mb-3">
            {cardData.map((_, i) => (
              <button class="carousel-dot w-1.5 h-1.5 rounded-full bg-white/30 transition-all duration-300 {i === 0 ? 'bg-white/80 w-3' : ''}" data-index={i} aria-label={`Card ${i + 1}`}></button>
            ))}
          </div>

          <!-- Action buttons -->
          <div class="grid grid-cols-2 gap-3 flex-shrink-0">
            <div class="flex items-center justify-center gap-1.5 py-3 px-4 rounded-xl bg-white/5 border border-white/10 text-white/50 hover:bg-destructive/10 hover:text-destructive hover:border-destructive/20 transition-all duration-300 cursor-pointer text-xs font-semibold select-none group/btn shadow-[0_2px_10px_rgba(0,0,0,0.1)]">
              <svg aria-hidden="true" class="w-4 h-4 text-white/40 group-hover/btn:text-destructive group-hover/btn:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
              {t.hero.phoneActions.discard}
            </div>
            <div class="flex items-center justify-center gap-1.5 py-3 px-4 rounded-xl bg-gradient-to-r from-primary/90 to-primary-light/90 border border-primary/20 text-white hover:shadow-[0_0_20px_rgba(79,70,229,0.3)] hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 cursor-pointer text-xs font-bold select-none group/btn">
              <svg aria-hidden="true" class="w-4 h-4 text-white/90 group-hover/btn:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {t.hero.phoneActions.select}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(function() {
  var slides = document.querySelectorAll('.card-slide');
  var badge = document.getElementById('card-badge');
  var dots = document.querySelectorAll('.carousel-dot');
  if (!slides.length || !badge) return;
  var codes = [];
  for (var s = 0; s < slides.length; s++) codes.push(slides[s].getAttribute('data-code'));
  var current = 0;
  var interval;

  function showCard(index) {
    for (var i = 0; i < slides.length; i++) {
      slides[i].style.opacity = i === index ? '1' : '0';
    }
    badge.textContent = codes[index];
    for (var j = 0; j < dots.length; j++) {
      if (j === index) { dots[j].classList.add('bg-white/80', 'w-3'); dots[j].classList.remove('bg-white/30', 'w-1.5'); }
      else { dots[j].classList.remove('bg-white/80', 'w-3'); dots[j].classList.add('bg-white/30', 'w-1.5'); }
    }
    current = index;
  }

  function nextCard() { showCard((current + 1) % slides.length); }
  function resetInterval() { clearInterval(interval); interval = setInterval(nextCard, 4000); }

  for (var k = 0; k < dots.length; k++) {
    dots[k].addEventListener('click', (function(idx) {
      return function() { if (idx !== current) { showCard(idx); resetInterval(); } };
    })(parseInt(dots[k].dataset.index)));
  }

  if (slides.length > 1) interval = setInterval(nextCard, 4000);
})();
</script>