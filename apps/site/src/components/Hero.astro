---
const PLAY_STORE_URL = 'https://play.google.com/store/apps/details?id=com.akit.app';
---

<section class="pt-32 pb-20 md:pt-40 md:pb-28 bg-bg" id="hero">
  <div class="container">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
      <!-- Content -->
      <div class="flex-1 text-center lg:text-left">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary-light mb-6">
          <span class="text-xs font-semibold text-primary tracking-wide uppercase">
            Modelo Holland RIASEC
          </span>
        </div>

        <!-- Heading -->
        <h1 class="font-display font-extrabold text-4xl sm:text-5xl lg:text-6xl text-text leading-[1.15] mb-6">
          Descubrí tu vocación<br />
          <span class="text-primary">en 10 minutos</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg text-text-muted leading-relaxed max-w-lg mx-auto lg:mx-0 mb-8">
          Deslizá cartas, descubrí tu perfil vocacional y recibí un reporte personalizado
          con las carreras que van con vos.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start mb-8">
          <a
            href={PLAY_STORE_URL}
            class="w-full sm:w-auto px-8 py-4 text-base font-bold text-surface bg-primary rounded-2xl hover:bg-primary-dark transition-all hover:shadow-lg hover:shadow-primary/20 text-center"
          >
            Empezá el test gratis
          </a>
          <a
            href="#como-funciona"
            class="w-full sm:w-auto px-8 py-4 text-base font-semibold text-primary bg-surface border-2 border-primary rounded-2xl hover:bg-primary-light/30 transition-all text-center"
          >
            Ver cómo funciona
          </a>
        </div>

        <!-- QR Code -->
        <div class="flex items-center gap-4 justify-center lg:justify-start">
          <div class="w-20 h-20 rounded-xl bg-surface border border-border flex items-center justify-center p-2">
            <!-- QR placeholder — replace with actual QR image -->
            <img
              src="/qr-playstore.svg"
              alt="Código QR para descargar en Google Play"
              class="w-full h-full object-contain rounded-lg"
              loading="lazy"
            />
          </div>
          <div class="text-left">
            <p class="text-sm font-semibold text-text">Escaneá para descargar</p>
            <p class="text-xs text-text-muted">Disponible en Google Play</p>
          </div>
        </div>
      </div>

      <!-- Phone Mockup -->
      <div class="flex-shrink-0">
        <div class="relative w-[280px] sm:w-[300px]">
          <!-- Phone frame -->
          <div class="bg-text rounded-[2.5rem] p-2 shadow-2xl">
            <div class="bg-surface rounded-[2rem] overflow-hidden">
              <!-- Status bar -->
              <div class="bg-primary-dark px-6 py-2 flex justify-between items-center">
                <span class="text-dark-text/60 text-xs">9:41</span>
                <div class="flex gap-1">
                  <div class="w-4 h-2 bg-dark-text/60 rounded-sm"></div>
                  <div class="w-2 h-2 bg-dark-text/60 rounded-sm"></div>
                </div>
              </div>

              <!-- App content -->
              <div class="p-5 flex flex-col items-center gap-5 min-h-[480px]">
                <h3 class="font-display font-bold text-xl text-text mt-4">¿Qué te interesa?</h3>

                <!-- Card -->
                <div class="w-full aspect-[3/4] max-h-[280px] rounded-3xl bg-surface border-2 border-border shadow-lg flex flex-col items-center justify-center p-6 gap-4">
                  <div class="w-16 h-16 rounded-full bg-primary-light flex items-center justify-center">
                    <span class="text-3xl">🎨</span>
                  </div>
                  <p class="font-display font-bold text-lg text-text text-center leading-tight">
                    Diseñar y crear<br />objetos visuales
                  </p>
                  <p class="text-sm text-text-muted text-center">
                    Usar colores, formas y materiales para expresar ideas
                  </p>
                </div>

                <!-- Actions -->
                <div class="flex items-center gap-6">
                  <button class="w-14 h-14 rounded-full bg-surface border-2 border-destructive flex items-center justify-center shadow-md" aria-label="No me interesa">
                    <span class="text-xl text-destructive font-bold">✕</span>
                  </button>
                  <button class="w-14 h-14 rounded-full bg-primary flex items-center justify-center shadow-md shadow-primary/30" aria-label="Me interesa">
                    <span class="text-xl text-surface">♥</span>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Decorative elements -->
          <div class="absolute -top-4 -right-4 w-20 h-20 bg-primary-light/50 rounded-full blur-xl"></div>
          <div class="absolute -bottom-6 -left-6 w-24 h-24 bg-secondary-light/50 rounded-full blur-xl"></div>
        </div>
      </div>
    </div>
  </div>
</section>
