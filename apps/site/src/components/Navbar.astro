---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { locale, t } = Astro.props;
const playStoreUrl = import.meta.env.PUBLIC_PLAY_STORE_URL || 'https://play.google.com/store/apps/details?id=com.akit.app';
const dashboardUrl = import.meta.env.PUBLIC_DASHBOARD_URL || 'https://app-qa.akituespacio.com.ar';

const langPath = locale === 'es' ? '/en' : '/';
---

<nav class="fixed top-4 left-0 right-0 z-50 flex justify-center px-4" role="navigation">
  <div class="w-full max-w-5xl bg-white/5 backdrop-blur-xl border border-white/10 rounded-full shadow-[0_8px_32px_rgba(0,0,0,0.3)] transition-all duration-300 hover:bg-white/10 hover:border-white/20">
    <div class="px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 group">
        <div class="relative w-9 h-9 rounded-xl bg-gradient-to-br from-primary to-emerald-400 p-[1px] group-hover:shadow-[0_0_20px_rgba(var(--primary-rgb),0.5)] transition-all duration-300">
          <div class="absolute inset-0 bg-dark-bg rounded-xl m-[1px] flex items-center justify-center overflow-hidden">
             <img src="/logo.png" alt="A.ki Logo" class="h-6 w-auto group-hover:scale-110 transition-transform duration-300" />
          </div>
        </div>
        <span class="font-display font-bold text-base text-white hidden sm:block tracking-wide">ORIENT A.KI</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        <a href="#como-funciona" class="text-sm font-medium text-white/70 hover:text-white hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.5)] transition-all">{t.nav.howItWorks}</a>
        <a href="#instituciones" class="text-sm font-medium text-white/70 hover:text-white hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.5)] transition-all">{t.nav.forInstitutions}</a>
        
        <div class="h-4 w-px bg-white/20"></div>
        
        <a href={langPath} class="text-sm font-bold text-white/50 hover:text-white transition-colors">{t.langSwitch}</a>
        
        <a href={dashboardUrl} class="px-5 py-2 text-sm font-bold text-dark-bg bg-white rounded-full hover:scale-105 hover:shadow-[0_0_20px_rgba(255,255,255,0.3)] transition-all duration-300">
          {t.nav.startFree}
        </a>
      </div>

      <div class="flex items-center gap-3 md:hidden">
        <a href={langPath} class="text-xs font-bold text-white/70 px-2">{t.langSwitch}</a>
        <button id="mobile-menu-btn" class="p-2 text-white/90 bg-white/10 rounded-full hover:bg-white/20 transition-colors" aria-label="Menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden absolute top-20 left-4 right-4 bg-dark-surface/95 backdrop-blur-2xl border border-white/10 rounded-2xl shadow-2xl p-4 md:hidden">
    <div class="flex flex-col gap-2">
      <a href="#como-funciona" class="px-4 py-3 text-sm font-medium text-white/80 hover:bg-white/5 rounded-xl transition-colors">{t.nav.howItWorks}</a>
      <a href="#instituciones" class="px-4 py-3 text-sm font-medium text-white/80 hover:bg-white/5 rounded-xl transition-colors">{t.nav.forInstitutions}</a>
      <a href={dashboardUrl} class="mt-2 w-full py-3 text-sm text-center text-dark-bg bg-white rounded-xl font-bold">{t.nav.startFree}</a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
  });
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => { menu?.classList.add('hidden'); btn?.setAttribute('aria-expanded', 'false'); });
  });
</script>
