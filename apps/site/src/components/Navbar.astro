---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { locale, t } = Astro.props;
const playStoreUrl = import.meta.env.PUBLIC_PLAY_STORE_URL || 'https://play.google.com/store/apps/details?id=com.akit.app';

const langPath = locale === 'es' ? '/en' : '/';
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg/90 backdrop-blur-md" role="navigation">
  <div class="container flex items-center justify-between h-14">
    <a href="/" class="flex items-center gap-2">
      <div class="w-7 h-7 rounded-md bg-primary flex items-center justify-center">
        <span class="text-white font-display font-bold text-xs">A</span>
      </div>
      <span class="font-display font-bold text-sm text-text hidden sm:block">ORIENT A.KI</span>
    </a>

    <div class="hidden md:flex items-center gap-6">
      <a href="#como-funciona" class="text-xs text-text-muted hover:text-primary transition-colors">{t.nav.howItWorks}</a>
      <a href="#instituciones" class="text-xs text-text-muted hover:text-primary transition-colors">{t.nav.forInstitutions}</a>
      <a href={langPath} class="text-xs text-text-muted hover:text-primary transition-colors">{t.langSwitch}</a>
      <a href={playStoreUrl} class="px-4 py-1.5 text-xs font-semibold text-surface bg-primary rounded-md hover:bg-primary-dark transition-colors">
        {t.nav.startFree}
      </a>
    </div>

    <div class="flex items-center gap-2 md:hidden">
      <a href={langPath} class="text-xs text-text-muted px-2">{t.langSwitch}</a>
      <button id="mobile-menu-btn" class="p-1.5 text-text" aria-label="Menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-surface border-t border-border">
    <div class="container py-3 flex flex-col gap-1">
      <a href="#como-funciona" class="py-2 text-sm text-text-muted">{t.nav.howItWorks}</a>
      <a href="#instituciones" class="py-2 text-sm text-text-muted">{t.nav.forInstitutions}</a>
      <a href={playStoreUrl} class="py-2.5 text-sm text-center text-surface bg-primary rounded-md font-semibold mt-2">{t.nav.startFree}</a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
  });
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => { menu?.classList.add('hidden'); btn?.setAttribute('aria-expanded', 'false'); });
  });
</script>
