---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { t } = Astro.props;
---

<section class="py-20 md:py-24 bg-bg" id="features">
  <div class="container">
    <h2 class="font-display font-extrabold text-3xl sm:text-4xl text-text text-center mb-14">
      {t.features.title}
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {t.features.items.map((feature, i) => {
        const icons = ['📴', '♿', '🌐', '📊', '🔒', '🎯'];
        return (
          <div class="bg-surface rounded-3xl border border-border p-7 flex flex-col gap-3 hover:shadow-md transition-shadow">
            <span class="text-3xl">{icons[i]}</span>
            <h3 class="font-display font-bold text-lg text-text">{feature.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{feature.desc}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
