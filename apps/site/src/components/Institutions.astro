---
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
}

const { t } = Astro.props;
---

<section class="py-20 md:py-28 bg-dark-bg relative overflow-hidden" id="instituciones">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-primary blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-tertiary blur-3xl"></div>
  </div>

  <div class="container relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
      {/* Left: Content */}
      <div class="flex-1">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-dark-surface border border-dark-border mb-6 reveal">
          <span class="w-2 h-2 rounded-full bg-tertiary animate-pulse"></span>
          <span class="text-xs font-semibold text-primary-light tracking-wide uppercase">{t.institutions.badge}</span>
        </div>

        <h2 class="font-display font-extrabold text-3xl sm:text-4xl lg:text-5xl text-dark-text leading-[1.1] mb-6 whitespace-pre-line reveal reveal-delay-1">
          {t.institutions.title}
        </h2>

        <p class="text-base text-dark-muted leading-relaxed mb-8 max-w-lg reveal reveal-delay-2">
          {t.institutions.desc}
        </p>

        {/* Feature list with checkmarks */}
        <ul class="flex flex-col gap-4 mb-8 reveal reveal-delay-3">
          {t.institutions.features.map((feature, i) => (
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-full bg-tertiary/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-dark-text text-sm font-medium">{feature}</span>
            </li>
          ))}
        </ul>

        <a
          href="mailto:contacto@orientaki.com"
          class="inline-flex items-center gap-2 px-6 py-3 text-sm font-bold text-surface bg-primary rounded-xl hover:bg-primary-dark transition-all hover:shadow-lg hover:shadow-primary/30 hover:-translate-y-0.5 reveal reveal-delay-4"
        >
          {t.institutions.cta}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      {/* Right: Dashboard mockup — floating card */}
      <div class="flex-shrink-0 w-full lg:w-[480px] reveal reveal-delay-2">
        <div class="relative">
          {/* Glow effect */}
          <div class="absolute -inset-4 bg-primary/10 rounded-3xl blur-2xl"></div>

          <div class="relative bg-dark-surface rounded-2xl border border-dark-border p-5 shadow-2xl">
            {/* Header */}
            <div class="flex items-center justify-between mb-5">
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-destructive"></div>
                <div class="w-3 h-3 rounded-full bg-warning"></div>
                <div class="w-3 h-3 rounded-full bg-confirm"></div>
              </div>
              <span class="text-dark-muted text-xs">{t.institutions.dashboard}</span>
            </div>

            {/* Stats */}
            <div class="grid grid-cols-3 gap-3 mb-5">
              <div class="bg-dark-border/50 rounded-xl p-3">
                <p class="text-primary-light font-extrabold text-xl">1,247</p>
                <p class="text-dark-muted text-[10px]">{t.institutions.stats.tests}</p>
              </div>
              <div class="bg-dark-border/50 rounded-xl p-3">
                <p class="text-tertiary font-extrabold text-xl">89%</p>
                <p class="text-dark-muted text-[10px]">{t.institutions.stats.completion}</p>
              </div>
              <div class="bg-dark-border/50 rounded-xl p-3">
                <p class="text-secondary-light font-extrabold text-xl">342</p>
                <p class="text-dark-muted text-[10px]">{t.institutions.stats.reports}</p>
              </div>
            </div>

            {/* Chart placeholder with bars */}
            <div class="bg-dark-border/50 rounded-xl p-4 h-44 flex items-end justify-between gap-2">
              {['R', 'I', 'A', 'S', 'E', 'C'].map((letter, i) => {
                const heights = ['60%', '80%', '45%', '90%', '70%', '55%'];
                const colors = ['bg-primary', 'bg-primary-light', 'bg-secondary', 'bg-tertiary', 'bg-secondary-light', 'bg-primary/60'];
                return (
                  <div class="flex flex-col items-center gap-2 flex-1">
                    <div class={`w-full rounded-t-lg ${colors[i]}`} style={`height: ${heights[i]}; opacity: 0.8;`}></div>
                    <span class="text-dark-muted text-xs font-mono">{letter}</span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
