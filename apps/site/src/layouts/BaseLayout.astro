---
import '../styles/global.css';
import type { Locale, Translation } from '../i18n/translations';

interface Props {
  locale: Locale;
  t: Translation;
  title: string;
  description?: string;
}

const { locale, title, description = locale === 'es'
  ? 'Descubrí tu vocación en 10 minutos con ORIENT A.KI. Test vocacional basado en el modelo Holland RIASEC.'
  : 'Discover your vocation in 10 minutes with ORIENT A.KI. Vocational test based on the Holland RIASEC model.' } = Astro.props;

const siteUrl = 'https://orientaki.com';
const ogImage = '/og-image.png';
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(ogImage, siteUrl)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={siteUrl} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(ogImage, siteUrl)} />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-white font-sans text-text antialiased selection:bg-primary/20 selection:text-primary">
		<slot />
	</body>
</html>
