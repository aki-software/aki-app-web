{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "swc",
    "deleteOutDir": false,
    "assets": [
      {
        "include": "**/*.pug",
        "watchAssets": true
      },
      {
        "include": "common/assets/**/*.json",
        "watchAssets": true
      }
    ]
  }
}
