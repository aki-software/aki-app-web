# ─────────────────────────────────────────────────────────────────
# A.kit API — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees el archivo .env al repositorio.
# ─────────────────────────────────────────────────────────────────

# ── Base de Datos PostgreSQL ──────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=REEMPLAZAR_CON_USUARIO_DB
DATABASE_PASSWORD=REEMPLAZAR_CON_PASSWORD_DB
DATABASE_NAME=akit_db

# ── Autenticación Admin ───────────────────────────────────────────
# Usuario y contraseña para el login del dashboard.
# Usar una contraseña segura de al menos 16 caracteres.
ADMIN_USER=REEMPLAZAR_CON_USUARIO_ADMIN
ADMIN_PASS=REEMPLAZAR_CON_PASSWORD_SEGURA

# ── Seed inicial (admin global + institución) ─────────────────────
# Se usa para inicializar una base nueva con un solo comando.
SEED_ADMIN_EMAIL=admin@akit.app
SEED_ADMIN_NAME=Platform Admin
SEED_ADMIN_PASSWORD=REEMPLAZAR_CON_PASSWORD_SEGURA_MIN_16

SEED_INSTITUTION_NAME=Institucion Demo A.KIT
SEED_INSTITUTION_BILLING_EMAIL=admin.institucion@akit.app
SEED_INSTITUTION_IS_ACTIVE=true
SEED_INSTITUTION_USER_EMAIL=institucion@akit.app
SEED_INSTITUTION_USER_NAME=Operador Institucion
SEED_INSTITUTION_USER_PASSWORD=REEMPLAZAR_CON_PASSWORD_SEGURA_MIN_16

# ── JWT ───────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens JWT.
# Generar con: openssl rand -base64 64
JWT_SECRET=REEMPLAZAR_CON_SECRET_ALEATORIO_MINIMO_32_CHARS
JWT_EXPIRATION=8h

# ── SMTP (Mailtrap para desarrollo / Resend para producción) ──
# transport type can be "smtp" (for mailtrap) or "pro" (for Resend)
MAIL_TRANSPORT_TYPE=smtp

# Dev (Mailtrap)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=REEMPLAZAR_CON_SMTP_USER
SMTP_PASS=REEMPLAZAR_CON_SMTP_PASS
SMTP_FROM="reportes@akit.app"

# Prod (Resend)
MAIL_PRO_HOST=smtp.resend.com
MAIL_PRO_PORT=465
MAIL_PRO_USER=resend
MAIL_PRO_PASS=re_your_api_key_here

# ── Queue / Redis (opcional) ───────────────────────────────────────
# Si no configuras Redis, la cola usa memoria y no es persistente.
# Opción recomendada (una sola URL):
REDIS_URL=redis://localhost:6379
# Alternativa por host/puerto:
REDIS_HOST=localhost
REDIS_PORT=6379
# Legacy soportado (equivalente a REDIS_URL):
QUEUE_REDIS_URL=redis://localhost:6379

# ── Servidor ──────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173
WEB_APP_URL=http://localhost:5173

# ── Google Play Billing ───────────────────────────────────────────
# Requerido para verificar compras in-app en Android
ANDROID_PACKAGE_NAME=com.akit.app
GOOGLE_PLAY_SERVICE_ACCOUNT_BASE64=REEMPLAZAR_CON_JSON_BASE64_DE_GOOGLE_PLAY_CONSOLE

# ── Vercel Serverless Deployment ──────────────────────────────────
# Required when deploying apps/api to Vercel as a serverless function.
# Set these in the Vercel dashboard under Project → Settings → Environment Variables.
#
# DATABASE_HOST=your-db-host.example.com
# DATABASE_PORT=5432
# DATABASE_USER=your_db_user
# DATABASE_PASSWORD=your_db_password
# DATABASE_NAME=akit_db
# JWT_SECRET=your_jwt_secret_min_32_chars
# JWT_EXPIRATION=8h
# CORS_ORIGIN=https://your-frontend.vercel.app
# ENABLE_BULLMQ=false
# NODE_ENV=production
# SERVERLESS=true
# PDF_LOGO_DATA_URI=data:image/png;base64,<base64-encoded-logo>  # Required in serverless (no disk access)

