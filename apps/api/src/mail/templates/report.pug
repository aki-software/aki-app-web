doctype html
html(lang="es")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Informe Vocacional — A.kit
    style.
      /* --- Estilo Minimalista A.kit --- */
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background-color: #fafafa;
        color: #18181b;
        line-height: 1.5;
        padding: 40px 10px;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 8px;
        border: 1px solid #e4e4e7;
        overflow: hidden;
      }
      .header {
        padding: 40px 32px 24px;
        text-align: left;
      }
      .logo {
        width: 44px;
        height: 44px;
        background: #4f46e5;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 24px;
      }
      .logo img { 
        width: 24px; 
        filter: brightness(0) invert(1);
        display: block;
      }
      h1 {
        font-size: 24px;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 8px;
        color: #09090b;
      }
      .subtitle {
        font-size: 16px;
        color: #71717a;
        margin-bottom: 32px;
      }
      .holland-badge {
        display: inline-block;
        background: #f4f4f5;
        padding: 4px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #52525b;
        margin-bottom: 40px;
      }
      .section-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #a1a1aa;
        margin-bottom: 16px;
        display: block;
      }
      .content-area { padding: 0 32px 40px; }
      .category-item {
        margin-bottom: 32px;
        border-bottom: 1px solid #f4f4f5;
        padding-bottom: 32px;
      }
      .category-item:last-child { border: none; }
      .cat-top {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 12px;
      }
      .cat-title {
        font-size: 18px;
        font-weight: 600;
        color: #18181b;
      }
      .cat-pct {
        font-size: 14px;
        font-weight: 500;
        color: #4f46e5;
      }
      .cat-desc {
        font-size: 14px;
        color: #52525b;
        margin-bottom: 16px;
      }
      .career-tags {
        display: block;
        margin-top: 12px;
      }
      .tag {
        display: inline-block;
        font-size: 11px;
        background: #eef2ff;
        color: #4338ca;
        padding: 2px 8px;
        border-radius: 4px;
        font-weight: 600;
        margin-right: 6px;
        margin-bottom: 6px;
      }
      .footer {
        background: #f9fafb;
        padding: 32px;
        text-align: center;
        border-top: 1px solid #f3f4f6;
      }
      .footer-text {
        font-size: 13px;
        color: #9ca3af;
        margin-bottom: 16px;
      }
      .contact-btn {
        display: inline-block;
        font-size: 14px;
        color: #4f46e5;
        text-decoration: none;
        font-weight: 600;
      }
      @media print {
        body { background: white; padding: 0; }
        .container { border: none; max-width: 100%; box-shadow: none; }
      }

  body
    .container
      .header
        .logo
          img(src="https://raw.githubusercontent.com/lucide-icons/lucide/main/icons/compass.svg" alt="A")
        h1 Informe de Resultados
        p.subtitle Hola #[strong #{patientName}], aquí tienes los detalles de tu exploración vocacional.
        if hollandCode
          span.holland-badge Código Holland: #{hollandCode}
      
      .content-area
        span.section-label Áreas de Afinidad
        
        each res, index in topResults
          .category-item
            .cat-top
              span.cat-title #{res.title}
              span.cat-pct #{res.percentage}%
            p.cat-desc #{res.description}
            
            if res.suggestedCareers && res.suggestedCareers.length > 0
              .career-tags
                each career in res.suggestedCareers
                  span.tag #{career}

      .footer
        p.footer-text Enviado automáticamente por Orient A.ki. Documento reservado para fines orientativos.
        a.contact-btn(href="mailto:soporte@orientaki.app") Soporte Técnico
