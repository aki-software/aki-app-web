doctype html
html(lang="es")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= titleText || 'A.kit'
  body(style="margin:0;padding:0;background:#{colors.background.light};font-family:Arial,'Helvetica Neue',Helvetica,sans-serif;color:#{colors.text.primary};")
    table(role="presentation" width="100%" cellpadding="0" cellspacing="0" style="padding:28px 0;background:#{colors.background.light};")
      tr
        td(align="center")
          table(role="presentation" width="620" cellpadding="0" cellspacing="0" style="width:620px;max-width:620px;background:#{colors.surface.light};border:1px solid #{colors.surface.variantLight};border-radius:22px;overflow:hidden;box-shadow:0 14px 32px rgba(15,107,104,0.10);")
            tr
              td(style="padding:30px;background:linear-gradient(135deg,#{colors.primary.DEFAULT} 0%,#2d8a87 60%,#4E7F52 100%);")
                include partials/email-header.pug

            block bodyContent

            tr
              td(style="padding:18px 30px 24px;background:#{colors.background.light};border-top:1px solid #{colors.surface.variantLight};")
                include partials/email-footer.pug
