table(role="presentation" width="100%" cellpadding="0" cellspacing="0")
  tr
    td(align="center")
      if logoDataUri
        img(src=logoDataUri alt="A.kit" style="width:110px;height:auto;display:block;")
      else
        span(style="font-size:26px;font-weight:800;color:#ffffff;letter-spacing:-0.01em;text-shadow:0 1px 4px rgba(0,0,0,0.18);") A.kit
  tr
    td(align="center" style="padding-top:10px;font-size:12px;color:rgba(255,255,255,0.82);text-transform:uppercase;letter-spacing:0.16em;font-weight:700;")= headerLabel || 'A.kit'
