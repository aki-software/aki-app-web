doctype html
html(lang="es")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Tu informe vocacional ya esta disponible
  body(style="margin:0;padding:0;background:#{colors.background.light};font-family:Arial,'Helvetica Neue',Helvetica,sans-serif;color:#2f2a25;")
    table(role="presentation" width="100%" cellpadding="0" cellspacing="0" style="padding:28px 0;background:#{colors.background.light};")
      tr
        td(align="center")
          table(role="presentation" width="620" cellpadding="0" cellspacing="0" style="width:620px;max-width:620px;background:#{colors.surface.light};border:1px solid #{colors.surface.variantLight};border-radius:22px;overflow:hidden;box-shadow:0 14px 32px rgba(86,62,39,0.12);")
            tr
              td(style="padding:30px;background:linear-gradient(135deg,#{colors.primary.DEFAULT} 0%,#2d8a87 60%,#4E7F52 100%);")
                table(role="presentation" width="100%" cellpadding="0" cellspacing="0")
                  tr
                    td(align="center")
                      if logoDataUri
                        img(src=logoDataUri alt="A.kit" style="width:110px;height:auto;display:block;")
                      else
                        span(style="font-size:26px;font-weight:800;color:#{colors.text.primary};letter-spacing:-0.01em;") A.kit
                  tr
                    td(align="center" style="padding-top:10px;font-size:12px;color:#{colors.outline.light};text-transform:uppercase;letter-spacing:0.16em;font-weight:700;") Informe Vocacional listo para descargar

            tr
              td(style="padding:26px 30px 6px;")
                h1(style="margin:0 0 4px 0;font-size:26px;line-height:1.2;color:#{colors.text.primary};letter-spacing:0.08em;text-transform:uppercase;") #{patientName}
                if patientEmail
                  p(style="margin:0 0 8px 0;font-size:12px;color:#{colors.outline.light};") #{patientEmail}
                p(style="margin:0 0 12px 0;font-size:14px;line-height:1.7;color:#{colors.outline.light};") Tu informe vocacional completo ya fue generado. En este correo te dejamos un resumen ejecutivo y el acceso al PDF.
                if hollandCode
                  span(style="display:inline-block;padding:6px 10px;border-radius:999px;background:#{colors.surface.variantLight};color:#{colors.primary.DEFAULT};font-size:10px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;") Codigo Holland: #{hollandCode}

            if summary
              tr
                td(style="padding:12px 30px 20px;")
                  table(role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border:1px solid #{colors.surface.variantLight};border-radius:16px;background:#{colors.surface.light};box-shadow:0 10px 20px rgba(86,62,39,0.08);")
                    tr
                      td(style="padding:18px 18px 6px;")
                        p(style="margin:0 0 6px 0;font-size:11px;font-weight:700;color:#{colors.outline.light};text-transform:uppercase;letter-spacing:0.18em;") Resumen rapido
                        p(style="margin:0 0 10px 0;font-size:16px;font-weight:700;color:#{colors.text.primary};") Afinidad principal: #{summary.primaryTitle} (#{summary.primaryPercentage}%)
                        p(style="margin:0 0 10px 0;font-size:14px;line-height:1.7;color:#{colors.text.secondary};") #{summary.profileStrength}
                        p(style="margin:0;font-size:14px;line-height:1.7;color:#{colors.text.secondary};") #[strong Sugerencia:] #{summary.recommendation}
                      if summary.rankedAreas && summary.rankedAreas.length > 0
                        tr
                          td(style="padding:0 18px 18px;")
                            p(style="margin:12px 0 10px 0;font-size:11px;font-weight:700;color:#{colors.outline.light};text-transform:uppercase;letter-spacing:0.18em;") Ranking de afinidad
                            table(role="presentation" width="100%" cellpadding="0" cellspacing="0")
                              each area, index in summary.rankedAreas
                                tr
                                  td(style="padding:6px 0;")
                                    table(role="presentation" width="100%" cellpadding="0" cellspacing="0")
                                      tr
                                        td(style="width:28px;font-size:12px;font-weight:700;color:#{colors.outline.light};") #{index + 1}.
                                        td(style="font-size:13px;color:#{colors.text.primary};font-weight:700;") #{area.title}
                                        td(style="width:56px;font-size:12px;color:#{colors.outline.light};text-align:right;") #{area.percentage}%
                                      tr
                                        td(colspan="3" style="padding-top:6px;")
                                          table(role="presentation" width="100%" cellpadding="0" cellspacing="0" style="height:6px;background:#{colors.surface.variantLight};border-radius:999px;overflow:hidden;")
                                            tr
                                              td(style=`width:${area.percentage}%;background:#{colors.primary.DEFAULT};height:6px;`)

            tr
              td(style="padding:6px 30px 26px;")
                table(role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border:1px solid #f1d7c1;background:#fde7d4;border-radius:16px;box-shadow:0 10px 20px rgba(86,62,39,0.08);")
                  tr
                    td(style="padding:18px;")
                      p(style="margin:0 0 12px 0;font-size:14px;font-weight:700;color:#{colors.text.primary};") Descargar informe completo en PDF
                      if reportUrl
                        a(href=reportUrl style="display:inline-block;padding:12px 18px;background:#{colors.primary.DEFAULT};color:#ffffff;text-decoration:none;border-radius:999px;font-size:13px;font-weight:700;box-shadow:0 8px 16px rgba(217,119,74,0.25);") Descargar PDF
                        p(style="margin:10px 0 0 0;font-size:12px;color:#{colors.outline.light};word-break:break-all;") #{reportUrl}
                      else
                        p(style="margin:0;font-size:13px;line-height:1.6;color:#{colors.outline.light};") El informe se adjunta en este mismo correo para que puedas abrirlo directamente.

            tr
              td(style="padding:18px 30px 24px;background:#{colors.background.light};border-top:1px solid #{colors.surface.variantLight};")
                p(style="margin:0 0 6px 0;font-size:11px;color:#{colors.outline.light};letter-spacing:0.08em;text-transform:uppercase;") A.kit - Orientacion vocacional asistida
                p(style="margin:0;font-size:12px;color:#{colors.outline.light};") #{brandDomain} · #{supportEmail}
                p(style="margin:6px 0 0;font-size:11px;color:#{colors.outline.light};") Documento reservado para fines orientativos.
