doctype html
html(lang="es")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Informe Vocacional - A.kit
    style.
      @page { margin: 24px; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        padding: 0;
        font-family: Georgia, 'Times New Roman', serif;
        color: #1f2937;
        background: #f7f8fb;
      }
      .page {
        max-width: 820px;
        margin: 0 auto;
        padding: 14px;
      }
      .hero {
        border: 1px solid #d7dbe4;
        border-radius: 8px;
        background: #ffffff;
        padding: 20px;
      }
      .brand-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .logo {
        width: 38px;
        height: 38px;
        border-radius: 8px;
        background: #1e3a8a;
        color: #fff;
        font-weight: 800;
        font-size: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .brand-text {
        font-size: 24px;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: #0f172a;
      }
      .hero-title {
        margin: 18px 0 6px;
        font-size: 28px;
        line-height: 1.2;
        color: #0f172a;
      }
      .hero-sub {
        margin: 0;
        font-size: 14px;
        line-height: 1.6;
        color: #334155;
      }
      .pill {
        display: inline-block;
        margin-top: 10px;
        padding: 5px 10px;
        border-radius: 999px;
        background: #e6edf9;
        color: #1e3a8a;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
      }
      .section {
        margin-top: 16px;
      }
      .section-title {
        margin: 0 0 10px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #334155;
      }
      .card {
        border: 1px solid #d8dee8;
        border-radius: 8px;
        background: #ffffff;
        padding: 14px;
      }
      .summary-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      .summary-metric {
        border: 1px solid #d6e1f3;
        border-radius: 6px;
        background: #f7fbff;
        padding: 10px;
      }
      .summary-metric h4 {
        margin: 0 0 6px;
        font-size: 11px;
        color: #1d4ed8;
        text-transform: uppercase;
      }
      .summary-metric p {
        margin: 0;
        font-size: 13px;
        line-height: 1.5;
      }
      .area-card {
        margin-bottom: 14px;
        border: 1px solid #d8dee8;
        border-radius: 8px;
        background: #fff;
        overflow: hidden;
      }
      .area-head {
        padding: 14px 16px;
        background: #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .area-head h3 {
        margin: 0;
        font-size: 20px;
        color: #0f172a;
      }
      .badge {
        padding: 5px 10px;
        border-radius: 999px;
        background: #1e3a8a;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
      }
      .area-content {
        padding: 14px 16px 8px;
      }
      .block-title {
        margin: 0 0 6px;
        font-size: 12px;
        color: #334155;
        text-transform: uppercase;
        letter-spacing: .06em;
        font-weight: 700;
      }
      .block-text {
        margin: 0 0 12px;
        font-size: 14px;
        line-height: 1.65;
        color: #374151;
      }
      .careers-card {
        margin-top: 10px;
        border: 1px solid #dbe3f3;
        border-radius: 6px;
        background: #f8fbff;
        padding: 12px;
      }
      .careers-card h4 {
        margin: 0 0 8px;
        color: #1d4ed8;
        font-size: 12px;
        text-transform: uppercase;
      }
      .careers-card ul,
      .triplet ul {
        margin: 0;
        padding-left: 18px;
      }
      .careers-card li,
      .triplet li {
        margin: 0 0 4px;
        font-size: 13px;
        line-height: 1.45;
      }
      .triplet {
        border: 1px solid #d5dfed;
        border-radius: 8px;
        background: #f8fbff;
        padding: 14px;
      }
      .triplet h3 {
        margin: 0 0 8px;
        color: #0f172a;
      }
      .triplet p {
        margin: 0 0 10px;
        font-size: 14px;
        line-height: 1.6;
      }
      .footer {
        margin-top: 18px;
        padding: 12px;
        border-top: 1px solid #d6dde8;
        text-align: center;
        color: #64748b;
        font-size: 11px;
      }
  body
    .page
      .hero
        .brand-row
          .brand
            .logo A
            .brand-text A.kit
          .pill Informe vocacional
        h1.hero-title Informe personalizado de orientacion
        p.hero-sub #{patientName}, este documento presenta tu perfil de afinidad, tus areas destacadas y una lectura integrada de tus intereses vocacionales.
        if hollandCode
          .pill(style="background:#e0e7ff;color:#312e81;") Codigo Holland: #{hollandCode}

      if summary
        .section
          p.section-title Resumen ejecutivo
          .card
            .summary-grid
              .summary-metric
                h4 Afinidad principal
                p #{summary.primaryTitle} (#{summary.primaryPercentage}%)
              .summary-metric
                h4 Recomendacion
                p #{summary.recommendation}
            .summary-metric(style="margin-top:10px;")
              h4 Fortaleza del perfil
              p #{summary.profileStrength}
            if summary.rankedAreas && summary.rankedAreas.length > 0
              .summary-metric(style="margin-top:10px;")
                h4 Ranking de afinidad
                ul
                  each area, index in summary.rankedAreas
                    li #{index + 1}. #{area.title} (#{area.percentage}%)

      .section
        p.section-title Analisis de areas de afinidad
        each res in topResults
          .area-card
            .area-head
              h3 #{res.title}
              .badge #{res.percentage}%
            .area-content
              if res.parsedBlocks && res.parsedBlocks.length > 0
                each block in res.parsedBlocks
                  if block.subtitle
                    p.block-title #{block.subtitle}
                  if block.content
                    p.block-text #{block.content}
              else
                p.block-text #{res.description}

              if res.suggestedCareers && res.suggestedCareers.length > 0
                .careers-card
                  h4 Carreras sugeridas
                  ul
                    each career in res.suggestedCareers
                      li #{career}

      if tripletInsight
        .section
          p.section-title Lectura integrada - tres areas
          .triplet
            h3 #{tripletInsight.title}
            p #{tripletInsight.narrative}
            if tripletInsight.tendencies && tripletInsight.tendencies.length > 0
              p.block-title Tendencias observadas
              ul
                each tendency in tripletInsight.tendencies
                  li #{tendency}
            if tripletInsight.possibleJobs && tripletInsight.possibleJobs.length > 0
              p.block-title Posibles ambitos de trabajo
              ul
                each job in tripletInsight.possibleJobs
                  li #{job}
            if tripletInsight.relatedProfessions && tripletInsight.relatedProfessions.length > 0
              p.block-title Profesiones vinculadas
              ul
                each profession in tripletInsight.relatedProfessions
                  li #{profession}

      .footer
        p(style="margin:0 0 4px;") A.kit - Orientacion vocacional asistida
        p(style="margin:0;") soporte@orientaki.app | Documento reservado para fines orientativos
