{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "moduleNameMapper": {
    "^@akit/contracts$": "<rootDir>/../../packages/contracts/src/index",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": "babel-jest"
  },
  "transformIgnorePatterns": [
    "/node_modules/(?!(@akit/contracts)/)"
  ]
}
