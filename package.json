{
  "name": "akit-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "dev:site": "pnpm --filter @akit/site dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:marketing": "turbo run dev --filter=@akit/site --filter=web",
    "build:site": "pnpm --filter @akit/site build",
    "preview:site": "pnpm --filter @akit/site preview",
    "test:stress:db": "node scripts/stress-db.mjs",
    "test:stress:puppeteer": "node scripts/stress-puppeteer.mjs",
    "test:stress:queue": "node scripts/stress-queue.mjs",
    "test:stress:cleanup": "node scripts/cleanup-stress-data.mjs",
    "test:flow": "node scripts/test-report-flow.mjs"
  },
  "devDependencies": {
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "pg": "^8.19.0",
    "turbo": "^2.8.12"
  },
  "dependencies": {
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@types/nodemailer": "^7.0.11",
    "@types/pug": "^2.0.10",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pug": "^3.0.3"
  }
}
